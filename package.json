{
  "name": "enviromaster-bi-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend/data platform + BI API for the EnviroMaster BI system: MongoDB models, ETL, RouteStar extraction, Express API (see docs/).",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "sync-indexes": "node scripts/sync-indexes.js",
    "seed": "node scripts/seed.js",
    "source:inspect": "node scripts/inspect-source.js",
    "status": "node scripts/status.js",
    "import:customers": "node scripts/import-inventory-customers.js",
    "import:routes": "node scripts/import-inventory-routes.js",
    "import:items": "node scripts/import-inventory-items.js",
    "import:pricing": "node scripts/import-inventory-pricing.js",
    "import:invoices": "node scripts/import-inventory-invoices.js",
    "import:payroll": "node scripts/import-payroll.js",
    "compute:legs": "node scripts/compute-route-legs.js",
    "drive:sync": "node scripts/compute-drive-time.js",
    "enrich:frequencies": "node scripts/enrich-invoice-frequencies.js",
    "distances:inspect": "node scripts/inspect-mapdistance.js",
    "materialize": "node scripts/rebuild-summaries.js",
    "check": "for f in $(find src scripts -name '*.js'); do node --check \"$f\"; done && echo ok",
    "rs:login": "node scripts/routestar-login.js",
    "rs:closed-invoices": "node scripts/routestar-closed-invoices.js",
    "rs:accounts": "node scripts/routestar-account-numbers.js",
    "playwright:install": "playwright install chromium"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongoose": "^8.5.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
