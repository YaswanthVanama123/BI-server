# ─────────────────────────────────────────────────────────────────────────────
# EnviroMaster BI — backend environment template. Copy to `.env` and fill real values.
# `.env` is gitignored. RouteStar values mirror the qa-tools/inventory-server setup.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database ---
# Same Atlas cluster AND same database as the inventory app (inventory_db). BI collections are written
# under BI_COLLECTION_PREFIX (default bi_) so they never collide with the app's own collections.
# SOURCE_DB_NAME is where the already-synced RouteStar collections (routestar*) are read from.
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/inventory_db?retryWrites=true&w=majority
SOURCE_DB_NAME=inventory_db
BI_COLLECTION_PREFIX=bi_
NODE_ENV=development

# --- BI API server (npm run dev / start) ---
PORT=4000
CORS_ORIGINS=http://localhost:5174
DEFAULT_TENANT_CODE=EM-NRV

# --- RouteStar (operational source; browser automation via Playwright) ---
ROUTESTAR_BASE_URL=https://emnrv.routestar.online
ROUTESTAR_USERNAME=your-routestar-username
ROUTESTAR_PASSWORD=your-routestar-password

# --- Playwright / browser ---
# HEADLESS=false only shows a window when a DISPLAY is present; otherwise stays headless.
HEADLESS=true
BROWSER_TIMEOUT=60000
# Where login/debug screenshots land (relative to the backend working dir).
SCREENSHOT_DIR=screenshots/routestar

# --- Mapbox (route distance / travel time / geocoding) ---
# Either name works; the enviromaster/structure project uses MAPBOX_ACCESS_TOKEN.
MAPBOX_TOKEN=your-mapbox-token

# --- Reporting / logging ---
TZ=America/New_York
REPORTING_TIMEZONE=America/New_York
LOG_LEVEL=info
